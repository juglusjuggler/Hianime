# Target website to mirror
TARGET_HOST=hianime.city

# Direct origin IP — bypasses Cloudflare completely
# Find this via DNS history or when CF is not enabled
ORIGIN_IP=5.182.209.112

# Your Railway domain (optional — auto-detected if not set)
# Set this to your custom domain or Railway-provided domain
# Example: yourdomain.up.railway.app or yourdomain.com
MIRROR_HOST=

# Upstream request timeout in ms (default: 30000)
UPSTREAM_TIMEOUT=30000

# Port (Railway sets this automatically, no need to change)
PORT=3000
